version: 1

formatters:
  precise:
    format: "%(asctime)s - %(name)s - %(lineno)d - %(levelname)s - %(message)s"

handlers:
  console:
    class: logging.StreamHandler
    formatter: precise
    level: INFO

root:
  level: INFO
  handlers: [console]

loggers:
  synapse.storage.SQL:
    level: WARNING
